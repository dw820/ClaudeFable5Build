# Copy to .env and fill in. Integration tests read these via vitest.config.ts (dotenv).
# Unit tests need NONE of these — `npm test` is green offline.

# Claude — builder (module 5) + verifier (module 4). Model: claude-opus-4-8
ANTHROPIC_API_KEY=

# Replicate — preprocess (module 6): whisper transcription, VLM frame captions, embeddings
REPLICATE_API_TOKEN=

# Supabase — OFF the demo path (preprocess pgvector + event writer)
SUPABASE_URL=
SUPABASE_KEY=

# Local media root for Clip.src resolution (demo uses local files, not Storage refs)
MEDIA_DIR=./media

# Integration-test gates — set to 1 to run the binary-dependent suites; unset = skipped
RUN_FFMPEG=
RUN_REMOTION=
