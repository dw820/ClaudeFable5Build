# Copy to .env and fill in. Integration tests read these via vitest.config.ts (dotenv).
# Unit tests need NONE of these — `npm test` is green offline.

# Claude — builder (module 5) + verifier (module 4). Model: claude-opus-4-8
ANTHROPIC_API_KEY=

# Replicate — preprocess (module 6): whisper transcription, VLM frame captions, embeddings
REPLICATE_API_TOKEN=

# Supabase — OFF the demo path (preprocess pgvector + event writer)
# Upload gate: when BOTH SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY (below) are
# set, preprocess uploads each source clip + clips.json to the private
# `source-clips` bucket and rewrites clip.src to a storage:// ref. If either is
# absent, nothing is uploaded and clip.src stays a local relative path.
SUPABASE_URL=
SUPABASE_KEY=

# Local media root for Clip.src resolution (demo uses local files, not Storage refs)
MEDIA_DIR=./media

# Integration-test gates — set to 1 to run the binary-dependent suites; unset = skipped
RUN_FFMPEG=
RUN_REMOTION=

# --- UI (Vercel/Next.js) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Daytona agent service (server) ---
SUPABASE_SERVICE_ROLE_KEY=
MEMORY_DIR=./.memory          # persistent on Daytona, e.g. /workspace/memory
RENDER_MODE=stub              # stub (deterministic demo) | real (ffmpeg + Claude)
